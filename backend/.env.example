# Database
DATABASE_URL=postgresql+asyncpg://quizbattle:secret@localhost:5432/quizbattle_db
SYNC_DATABASE_URL=postgresql+psycopg2://quizbattle:secret@localhost:5432/quizbattle_db

# Redis
REDIS_URL=redis://:redissecret@localhost:6379/0

# JWT
JWT_SECRET_KEY=dev_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000

# AI (Google Gemini - Free Tier)
# Get your free API key at: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here
